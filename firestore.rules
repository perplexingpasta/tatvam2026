rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all client reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }
    // Allow client reads on events collection only
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }
  }
}